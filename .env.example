# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# ------------------------------------------------------------------
# Database paths
# ------------------------------------------------------------------
DB_PATH=data/db/trading.db
MARKET_DB_PATH=data/db/market_data.db

# ------------------------------------------------------------------
# Alpaca (US stocks)
# ------------------------------------------------------------------
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Set to false for live trading (default: true = paper trading endpoint)
ALPACA_PAPER=true

# Data feed: "iex" = free tier (IEX exchange, may be incomplete for some symbols)
#            "sip" = consolidated tape (requires Alpaca Unlimited plan)
ALPACA_DATA_FEED=iex

# ------------------------------------------------------------------
# Taiwan broker — set TW_BROKER to "shioaji" or "fugle"
# ------------------------------------------------------------------
TW_BROKER=shioaji

# Simulation (paper trading) — true = no certificate needed
# Set to false for live order execution
SHIOAJI_SIMULATION=true

SHIOAJI_API_KEY=
SHIOAJI_SECRET_KEY=

# Certificate — required only when SHIOAJI_SIMULATION=false
# Leave blank for simulation mode
SHIOAJI_CERT_PATH=
SHIOAJI_CERT_PASSWORD=
SHIOAJI_PERSON_ID=

FUGLE_API_KEY=
FUGLE_SECRET_KEY=

# ------------------------------------------------------------------
# Alerts (all optional)
# ------------------------------------------------------------------
LINE_NOTIFY_TOKEN=
SLACK_WEBHOOK_URL=
ALERT_EMAIL=

# ------------------------------------------------------------------
# LINE Messaging API (Push Message) — all optional, absence = log-only
# Get Channel Access Token: LINE Developers Console → Messaging API → Channel access token
# ------------------------------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_USER_ID=

# ------------------------------------------------------------------
# SMTP email notifications (all optional — absence = log-only mode)
# ------------------------------------------------------------------
# SMTP server hostname
SMTP_HOST=

# SMTP port: 587 (STARTTLS, recommended) or 465 (SSL)
SMTP_PORT=587

# Sender login (usually your email address)
SMTP_USER=

# Password or app-specific password (e.g. Gmail App Password)
SMTP_PASS=

# Recipient address for alerts and daily reports
NOTIFY_EMAIL=
